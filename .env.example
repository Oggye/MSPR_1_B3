# ===============================================
# ObRail - Local runtime variables
# Copy to .env and adjust values for your machine.
# ===============================================

# ---------- PostgreSQL / API / ETL ----------
DB_HOST=db
DB_PORT=5432
DB_NAME=obrail
DB_USER=obrail_user
DB_PASSWORD=change_me_in_real_env

# Secret used by API features that rely on token signing.
JWT_SECRET=change_this_secret_value

# ---------- Monitoring endpoints ----------
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000

# ---------- Frontend (internal/admin + external UI) ----------
# URL used by React app to reach FastAPI.
REACT_APP_API_URL=http://localhost:8000

# ---------- CI/CD expected secrets ----------
# Used by the workflow when deploying a testable stack or external integrations.
# Keep empty in local .env unless explicitly required.
API_KEY=example_api_key_for_ci
DB_URL=postgresql://obrail_user:change_me_in_real_env@db:5432/obrail

# ---------- Optional CI metadata ----------
# GITHUB_TOKEN is provided automatically by GitHub Actions.
# Do not hardcode it locally.
